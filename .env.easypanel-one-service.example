APP_NAME=WeeBudget
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:replace-with-generated-laravel-key
APP_URL=https://domain-kamu.com
FRONTEND_URL=https://domain-kamu.com

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
LOG_CHANNEL=stack

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://domain-kamu.com/api/auth/google/callback
EMAS_BASE_URL=https://emas.maulanar.my.id
EMAS_API_KEY=
SANCTUM_STATEFUL_DOMAINS=domain-kamu.com
SANCTUM_EXPIRATION=null
WEEB_ALLOW_GUEST_USER=false
WEEB_ADMIN_NAME=Admin WeeBudget
WEEB_ADMIN_EMAIL=admin@example.com
WEEB_ADMIN_PASSWORD=replace-with-strong-password
